  admin_users_returnable_checkouts_returned_verified_by_admin_idToadmin_users admin_users?       @relation("returnable_checkouts_returned_verified_by_admin_idToadmin_users", fields: [returned_verified_by_admin_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

