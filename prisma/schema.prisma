model smart_lock_access {
  id                    String                  @id @db.VarChar(36)
  ezee_reservation_id   String                  @db.VarChar(100)
  guest_id              String                  @db.VarChar(36)
  device_id             String                  @db.VarChar(36)
  room_number           String                  @db.VarChar(20)
  mygate_pin            String                  @db.VarChar(20)
  pin_type              String                  @default("AUTO") @db.VarChar(10)
  pin_validity          String                  @default("TIMED") @db.VarChar(10)
  is_master_pin         Boolean                 @default(false)
  pin_status            String                  @default("ACTIVE") @db.VarChar(10)
  valid_from            DateTime                @db.Timestamp(6)
  valid_until           DateTime?               @db.Timestamp(6)
  created_at            DateTime                @default(now()) @db.Timestamp(6)
