generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model addon_order_items {
  id                   String                 @id @db.VarChar(36)
  addon_order_id       String                 @db.VarChar(36)
  product_id           String                 @db.VarChar(36)
  quantity             Int                    @default(1)
  unit_price           Decimal                @db.Decimal(10, 2)
  total_price          Decimal                @db.Decimal(10, 2)
  unit_code            String?                @db.VarChar(20)
  addon_orders         addon_orders           @relation(fields: [addon_order_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  product_catalog      product_catalog        @relation(fields: [product_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  returnable_checkouts returnable_checkouts[]
}

model addon_orders {
  id                  String              @id @db.VarChar(36)
  ezee_reservation_id String              @db.VarChar(100)
  guest_id            String              @db.VarChar(36)
  payment_id          String?             @db.VarChar(36)
  phase               String              @db.VarChar(20)
  status              String              @default("PENDING") @db.VarChar(20)
  ezee_sync_status    String              @default("NOT_SYNCED") @db.VarChar(20)
  created_at          DateTime            @default(now()) @db.Timestamp(6)
  addon_order_items   addon_order_items[]
  ezee_booking_cache  ezee_booking_cache  @relation(fields: [ezee_reservation_id], references: [ezee_reservation_id], onDelete: NoAction, onUpdate: NoAction)
  guests              guests              @relation(fields: [guest_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  payments            payments?           @relation(fields: [payment_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  zoho_ticket_ref     zoho_ticket_ref[]

  @@index([ezee_reservation_id], map: "idx_addon_orders_reservation")
}

model admin_activity_log {
  id          String   @id @db.VarChar(36)
  actor_type  String   @db.VarChar(20)
  actor_id    String   @db.VarChar(100)
  action      String   @db.VarChar(50)
  entity_type String   @db.VarChar(50)
  entity_id   String   @db.VarChar(36)
  old_value   Json?
  new_value   Json?
  ip_address  String?  @db.VarChar(45)
  created_at  DateTime @default(now()) @db.Timestamp(6)

  @@index([actor_id, created_at], map: "idx_admin_log_actor")
  @@index([entity_type, entity_id], map: "idx_admin_log_entity")
}

model admin_roles {
  id           String        @id @db.VarChar(36)
  name         String        @unique @db.VarChar(50)
  display_name String        @db.VarChar(100)
  permissions  Json
  is_active    Boolean       @default(true)
  created_at   DateTime      @default(now()) @db.Timestamp(6)
  admin_users  admin_users[]
}

model admin_users {
  id                                                                                   String                 @id @db.VarChar(36)
  name                                                                                 String                 @db.VarChar(255)
  email                                                                                String                 @unique @db.VarChar(255)
  phone                                                                                String?                @db.VarChar(20)
  password_hash                                                                        String                 @db.VarChar(255)
  role_id                                                                              String                 @db.VarChar(36)
  property_id                                                                          String?                @db.VarChar(36)
  is_active                                                                            Boolean                @default(true)
  two_fa_enabled                                                                       Boolean                @default(false)
  two_fa_secret                                                                        String?                @db.VarChar(255)
  last_login_at                                                                        DateTime?              @db.Timestamp(6)
  created_at                                                                           DateTime               @default(now()) @db.Timestamp(6)
  updated_at                                                                           DateTime               @default(now()) @db.Timestamp(6)
  properties                                                                           properties?            @relation(fields: [property_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  admin_roles                                                                          admin_roles            @relation(fields: [role_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  borrowable_checkouts                                                                 borrowable_checkouts[]
  events                                                                               events[]
  returnable_checkouts_returnable_checkouts_issued_by_admin_idToadmin_users            returnable_checkouts[] @relation("returnable_checkouts_issued_by_admin_idToadmin_users")
  returnable_checkouts_returnable_checkouts_returned_verified_by_admin_idToadmin_users returnable_checkouts[] @relation("returnable_checkouts_returned_verified_by_admin_idToadmin_users")

  @@index([email, is_active], map: "idx_admin_users_email_active")
  @@index([role_id], map: "idx_admin_users_role")
}

model auth_providers {
  id           String   @id @db.VarChar(36)
  guest_id     String   @db.VarChar(36)
  provider     String   @db.VarChar(50)
  provider_uid String   @db.VarChar(255)
  created_at   DateTime @default(now()) @db.Timestamp(6)
  guests       guests   @relation(fields: [guest_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([provider, provider_uid])
}

model booking_guest_access {
  id                                                       String             @id @db.VarChar(36)
  ezee_reservation_id                                      String             @db.VarChar(100)
  guest_id                                                 String             @db.VarChar(36)
  role                                                     String             @db.VarChar(20)
  status                                                   String             @default("PENDING_APPROVAL") @db.VarChar(30)
  approved_by_guest_id                                     String?            @db.VarChar(36)
  approved_at                                              DateTime?          @db.Timestamp(6)
  created_at                                               DateTime           @default(now()) @db.Timestamp(6)
  guests_booking_guest_access_approved_by_guest_idToguests guests?            @relation("booking_guest_access_approved_by_guest_idToguests", fields: [approved_by_guest_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  ezee_booking_cache                                       ezee_booking_cache @relation(fields: [ezee_reservation_id], references: [ezee_reservation_id], onDelete: NoAction, onUpdate: NoAction)
  guests_booking_guest_access_guest_idToguests             guests             @relation("booking_guest_access_guest_idToguests", fields: [guest_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([ezee_reservation_id, guest_id])
  @@index([guest_id], map: "idx_booking_access_guest")
  @@index([ezee_reservation_id], map: "idx_booking_access_reservation")
}

model booking_slots {
  id                  String             @id @db.VarChar(36)
  ezee_reservation_id String             @db.VarChar(100)
  slot_number         Int
  guest_id            String?            @db.VarChar(36)
  label               String             @db.VarChar(50)
  kyc_status          String             @default("NOT_STARTED") @db.VarChar(20)
  created_at          DateTime           @default(now()) @db.Timestamp(6)
  ezee_booking_cache  ezee_booking_cache @relation(fields: [ezee_reservation_id], references: [ezee_reservation_id], onDelete: NoAction, onUpdate: NoAction)
  guests              guests?            @relation(fields: [guest_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  kyc_submissions     kyc_submissions[]

  @@unique([ezee_reservation_id, slot_number])
  @@index([ezee_reservation_id], map: "idx_booking_slots_eri")
}

model borrowable_checkouts {
  id                                 String             @id @db.VarChar(36)
  inventory_id                       String             @db.VarChar(36)
  ezee_reservation_id                String             @db.VarChar(100)
  guest_id                           String             @db.VarChar(36)
  unit_code                          String             @db.VarChar(20)
  checked_out_at                     DateTime           @default(now()) @db.Timestamp(6)
  returned_at                        DateTime?          @db.Timestamp(6)
  returned_verified_by_zoho_staff_id String?            @db.VarChar(100)
  status                             String             @default("CHECKED_OUT") @db.VarChar(15)
  issued_by_admin_id                 String?            @db.VarChar(255)
  ezee_booking_cache                 ezee_booking_cache @relation(fields: [ezee_reservation_id], references: [ezee_reservation_id], onDelete: NoAction, onUpdate: NoAction)
  guests                             guests             @relation(fields: [guest_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  inventory                          inventory          @relation(fields: [inventory_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  admin_users                        admin_users?       @relation(fields: [issued_by_admin_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_borrowable_issued_by")

  @@index([guest_id, status], map: "idx_borrowable_guest_status")
}

model checkin_records {
  id                        String             @id @db.VarChar(36)
  ezee_reservation_id       String             @db.VarChar(100)
  guest_id                  String             @db.VarChar(36)
  selfie_url                String?            @db.VarChar(500)
  face_match_score          Decimal?           @db.Decimal(4, 3)
  face_match_status         String?            @db.VarChar(10)
  onsite_scan_url           String?            @db.VarChar(500)
  ssim_score                Decimal?           @db.Decimal(4, 3)
  doc_match_status          String?            @db.VarChar(10)
  gcard_pdf_url             String?            @db.VarChar(500)
  signature_png_url         String?            @db.VarChar(500)
  manual_override           Boolean            @default(false)
  override_by_zoho_staff_id String?            @db.VarChar(100)
  status                    String             @default("PENDING") @db.VarChar(20)
  checked_in_at             DateTime?          @db.Timestamp(6)
  ezee_booking_cache        ezee_booking_cache @relation(fields: [ezee_reservation_id], references: [ezee_reservation_id], onDelete: NoAction, onUpdate: NoAction)
  guests                    guests             @relation(fields: [guest_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([ezee_reservation_id], map: "idx_checkin_reservation")
}

model events {
  id           String       @id @db.VarChar(36)
  property_id  String       @db.VarChar(36)
  title        String       @db.VarChar(200)
  description  String?
  date         DateTime     @db.Date
  time         String?      @db.VarChar(10)
  location     String?      @db.VarChar(200)
  capacity     Int?
  price_text   String?      @db.VarChar(100)
  contact_link String?      @db.VarChar(500)
  poster_url   String?      @db.VarChar(500)
  badge_label  String?      @db.VarChar(30)
  badge_color  String?      @db.VarChar(10)
  is_active    Boolean      @default(true)
  created_by   String?      @db.VarChar(36)
  created_at   DateTime     @default(now()) @db.Timestamp(6)
  updated_at   DateTime     @default(now()) @db.Timestamp(6)
  admin_users  admin_users? @relation(fields: [created_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
  properties   properties   @relation(fields: [property_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([property_id, date], map: "idx_events_property_date")
}

model ezee_booking_cache {
  ezee_reservation_id      String                 @id @db.VarChar(100)
  property_id              String                 @db.VarChar(36)
  guest_id                 String?                @db.VarChar(36)
  booker_email             String?                @db.VarChar(255)
  booker_phone             String?                @db.VarChar(20)
  room_type_name           String?                @db.VarChar(100)
  room_number              String?                @db.VarChar(20)
  unit_code                String?                @db.VarChar(20)
  checkin_date             DateTime?              @db.Date
  checkout_date            DateTime?              @db.Date
  no_of_guests             Int?                   @default(1)
  source                   String?                @db.VarChar(50)
  status                   String?                @db.VarChar(30)
  is_active                Boolean                @default(true)
  fetched_at               DateTime               @db.Timestamp(6)
  created_at               DateTime               @default(now()) @db.Timestamp(6)
  ezee_reservation_no      String?                @db.VarChar(100)
  ezee_sub_reservation_nos String?
  booking_rooms_json       Json?
  addon_orders             addon_orders[]
  booking_guest_access     booking_guest_access[]
  booking_slots            booking_slots[]
  borrowable_checkouts     borrowable_checkouts[]
  checkin_records          checkin_records[]
  guests                   guests?                @relation(fields: [guest_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  properties               properties             @relation(fields: [property_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  kyc_submissions          kyc_submissions[]
  payments                 payments[]
  returnable_checkouts     returnable_checkouts[]
  smart_lock_access        smart_lock_access[]
  stay_extensions          stay_extensions[]
  zoho_ticket_ref          zoho_ticket_ref[]

  @@index([guest_id], map: "idx_ezee_cache_guest")
  @@index([property_id, status], map: "idx_ezee_cache_property")
}

model ezee_connection {
  id                 String     @id @db.VarChar(36)
  property_id        String     @db.VarChar(36)
  hotel_code         String     @db.VarChar(100)
  api_key            String     @db.VarChar(255)
  api_endpoint       String     @db.VarChar(500)
  channel_manager_id String?    @db.VarChar(100)
  is_active          Boolean    @default(true)
  created_at         DateTime   @default(now()) @db.Timestamp(6)
  updated_at         DateTime   @default(now()) @db.Timestamp(6)
  properties         properties @relation(fields: [property_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model ezee_sync_log {
  id                String    @id @db.VarChar(36)
  entity_type       String    @db.VarChar(30)
  entity_id         String    @db.VarChar(36)
  action            String    @db.VarChar(50)
  status            String    @default("PENDING") @db.VarChar(10)
  attempts          Int       @default(0)
  last_attempted_at DateTime? @db.Timestamp(6)
  next_retry_at     DateTime? @db.Timestamp(6)
  error_message     String?
  created_at        DateTime  @default(now()) @db.Timestamp(6)

  @@index([status, next_retry_at], map: "idx_ezee_sync_status_retry")
}

model guests {
  id                                                                     String                  @id @db.VarChar(36)
  name                                                                   String                  @db.VarChar(255)
  email                                                                  String?                 @unique @db.VarChar(255)
  phone                                                                  String?                 @unique @db.VarChar(20)
  password_hash                                                          String?                 @db.VarChar(255)
  email_verified                                                         Boolean                 @default(false)
  phone_verified                                                         Boolean                 @default(false)
  profile_photo_url                                                      String?                 @db.VarChar(500)
  created_at                                                             DateTime                @default(now()) @db.Timestamp(6)
  addon_orders                                                           addon_orders[]
  auth_providers                                                         auth_providers[]
  booking_guest_access_booking_guest_access_approved_by_guest_idToguests booking_guest_access[]  @relation("booking_guest_access_approved_by_guest_idToguests")
  booking_guest_access_booking_guest_access_guest_idToguests             booking_guest_access[]  @relation("booking_guest_access_guest_idToguests")
  booking_slots                                                          booking_slots[]
  borrowable_checkouts                                                   borrowable_checkouts[]
  checkin_records                                                        checkin_records[]
  ezee_booking_cache                                                     ezee_booking_cache[]
  kyc_submissions_kyc_submissions_guest_idToguests                       kyc_submissions[]       @relation("kyc_submissions_guest_idToguests")
  kyc_submissions_kyc_submissions_submitted_by_guest_idToguests          kyc_submissions[]       @relation("kyc_submissions_submitted_by_guest_idToguests")
  notification_log                                                       notification_log[]
  otp_logs                                                               otp_logs[]
  payments                                                               payments[]
  returnable_checkouts                                                   returnable_checkouts[]
  smart_lock_access                                                      smart_lock_access[]
  stay_extensions                                                        stay_extensions[]
  zoho_ticket_ref                                                        zoho_ticket_ref[]
  colive_quotes                                                          colive_quotes[]
  colive_draft_bookings                                                  colive_draft_bookings[]
}

model inventory {
  id                   String                 @id @db.VarChar(36)
  property_id          String                 @db.VarChar(36)
  product_id           String                 @db.VarChar(36)
  total_stock          Int
  available_stock      Int
  reserved_stock       Int                    @default(0)
  sold_count           Int                    @default(0)
  damaged_count        Int                    @default(0)
  borrowed_out_count   Int                    @default(0)
  low_stock_threshold  Int                    @default(5)
  updated_at           DateTime               @default(now()) @db.Timestamp(6)
  borrowable_checkouts borrowable_checkouts[]
  product_catalog      product_catalog        @relation(fields: [product_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  properties           properties             @relation(fields: [property_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  returnable_checkouts returnable_checkouts[]

  @@unique([property_id, product_id])
  @@index([property_id, product_id], map: "idx_inventory_product")
}

model kyc_submissions {
  id                                                   String             @id @db.VarChar(36)
  ezee_reservation_id                                  String             @db.VarChar(100)
  guest_id                                             String             @db.VarChar(36)
  nationality_type                                     String             @db.VarChar(20)
  id_type                                              String             @db.VarChar(20)
  front_image_url                                      String?            @db.VarChar(500)
  back_image_url                                       String?            @db.VarChar(500)
  ocr_name                                             String?            @db.VarChar(255)
  ocr_dob                                              String?            @db.VarChar(20)
  ocr_id_number                                        String?            @db.VarChar(100)
  ocr_address                                          String?
  coming_from                                          String?            @db.VarChar(255)
  going_to                                             String?            @db.VarChar(255)
  purpose                                              String?            @db.VarChar(255)
  consent_given                                        Boolean            @default(false)
  status                                               String             @default("PENDING") @db.VarChar(20)
  submitted_at                                         DateTime?          @db.Timestamp(6)
  created_at                                           DateTime           @default(now()) @db.Timestamp(6)
  slot_id                                              String?            @db.VarChar(36)
  full_name                                            String?            @db.VarChar(255)
  date_of_birth                                        DateTime?          @db.Date
  id_number                                            String?            @db.VarChar(100)
  permanent_address                                    String?
  contact_number                                       String?            @db.VarChar(20)
  submitted_by_guest_id                                String?            @db.VarChar(36)
  ezee_booking_cache                                   ezee_booking_cache @relation(fields: [ezee_reservation_id], references: [ezee_reservation_id], onDelete: NoAction, onUpdate: NoAction)
  guests_kyc_submissions_guest_idToguests              guests             @relation("kyc_submissions_guest_idToguests", fields: [guest_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  booking_slots                                        booking_slots?     @relation(fields: [slot_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  guests_kyc_submissions_submitted_by_guest_idToguests guests?            @relation("kyc_submissions_submitted_by_guest_idToguests", fields: [submitted_by_guest_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([ezee_reservation_id, guest_id], map: "idx_kyc_reservation")
  @@index([slot_id], map: "idx_kyc_slot")
}

model mygate_connection {
  id                 String     @id @db.VarChar(36)
  property_id        String     @db.VarChar(36)
  mygate_property_id String     @db.VarChar(100)
  api_key            String     @db.VarChar(255)
  api_endpoint       String     @db.VarChar(500)
  admin_phone        String?    @db.VarChar(20)
  is_active          Boolean    @default(true)
  created_at         DateTime   @default(now()) @db.Timestamp(6)
  updated_at         DateTime   @default(now()) @db.Timestamp(6)
  properties         properties @relation(fields: [property_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model mygate_devices {
  id                    String                  @id @db.VarChar(36)
  property_id           String                  @db.VarChar(36)
  room_number           String                  @db.VarChar(20)
  mygate_room_id        String                  @db.VarChar(100)
  lock_serial           String                  @db.VarChar(100)
  lock_type             String                  @db.VarChar(20)
  battery_pct           Int?
  battery_status        String                  @default("OK") @db.VarChar(10)
  last_health_at        DateTime?               @db.Timestamp(6)
  has_manual_key        Boolean                 @default(true)
  is_active             Boolean                 @default(true)
  created_at            DateTime                @default(now()) @db.Timestamp(6)
  properties            properties              @relation(fields: [property_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  smart_lock_access     smart_lock_access[]
  smart_lock_access_log smart_lock_access_log[]

  @@index([property_id, is_active], map: "idx_device_property")
}

model notification_log {
  id                      String   @id @db.VarChar(36)
  recipient_guest_id      String?  @db.VarChar(36)
  recipient_zoho_staff_id String?  @db.VarChar(100)
  channel                 String   @db.VarChar(20)
  type                    String   @db.VarChar(50)
  payload                 Json?
  status                  String   @default("SENT") @db.VarChar(10)
  sent_at                 DateTime @default(now()) @db.Timestamp(6)
  guests                  guests?  @relation(fields: [recipient_guest_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model otp_logs {
  id         String    @id @db.VarChar(36)
  guest_id   String?   @db.VarChar(36)
  recipient  String    @db.VarChar(255)
  channel    String    @db.VarChar(20)
  purpose    String    @db.VarChar(50)
  otp_hash   String    @db.VarChar(255)
  expires_at DateTime  @db.Timestamp(6)
  used_at    DateTime? @db.Timestamp(6)
  created_at DateTime  @default(now()) @db.Timestamp(6)
  guests     guests?   @relation(fields: [guest_id], references: [id], onUpdate: NoAction)
}

model payments {
  id                  String             @id @db.VarChar(36)
  ezee_reservation_id String             @db.VarChar(100)
  guest_id            String             @db.VarChar(36)
  razorpay_order_id   String?            @unique @db.VarChar(100)
  razorpay_payment_id String?            @unique @db.VarChar(100)
  amount              Decimal            @db.Decimal(10, 2)
  currency            String             @default("INR") @db.VarChar(5)
  purpose             String             @db.VarChar(30)
  status              String             @default("PENDING") @db.VarChar(20)
  expires_at          DateTime?          @db.Timestamp(6)
  created_at          DateTime           @default(now()) @db.Timestamp(6)
  updated_at          DateTime           @default(now()) @db.Timestamp(6)
  addon_orders        addon_orders[]
  ezee_booking_cache  ezee_booking_cache @relation(fields: [ezee_reservation_id], references: [ezee_reservation_id], onDelete: NoAction, onUpdate: NoAction)
  guests              guests             @relation(fields: [guest_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  stay_extensions     stay_extensions[]

  @@index([ezee_reservation_id], map: "idx_payments_reservation")
  @@index([status, expires_at], map: "idx_payments_status_expires")
}

model product_catalog {
  id                String              @id @db.VarChar(36)
  property_id       String              @db.VarChar(36)
  name              String              @db.VarChar(255)
  description       String?
  category          String              @db.VarChar(20)
  base_price        Decimal             @default(0) @db.Decimal(10, 2)
  is_active         Boolean             @default(true)
  addon_order_items addon_order_items[]
  inventory         inventory[]
  properties        properties          @relation(fields: [property_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model properties {
  id                       String                    @id @db.VarChar(36)
  name                     String                    @db.VarChar(255)
  address                  String
  city                     String                    @db.VarChar(100)
  branding_config          Json?
  created_at               DateTime                  @default(now()) @db.Timestamp(6)
  admin_users              admin_users[]
  events                   events[]
  ezee_booking_cache       ezee_booking_cache[]
  ezee_connection          ezee_connection[]
  inventory                inventory[]
  mygate_connection        mygate_connection[]
  mygate_devices           mygate_devices[]
  product_catalog          product_catalog[]
  room_types               room_types[]
  sla_config               sla_config[]
  colive_property_content  colive_property_content[]
  colive_room_options      colive_room_options[]
  colive_addons            colive_addons[]
  colive_quotes            colive_quotes[]
  colive_draft_bookings    colive_draft_bookings[]
}

// ─── COLIVE LONG-STAY TABLES ─────────────────────────────────────────────────

model colive_locations {
  id                      String                    @id @db.VarChar(36)
  slug                    String                    @unique @db.VarChar(50)
  label                   String                    @db.VarChar(100)
  is_active               Boolean                   @default(true)
  created_at              DateTime                  @default(now()) @db.Timestamp(6)
  colive_property_content colive_property_content[]
}

model colive_plans {
  id                    String   @id @db.VarChar(36)
  slug                  String   @unique @db.VarChar(50)
  title                 String   @db.VarChar(100)
  description           String?
  recommended_stay_type String   @db.VarChar(20)
  accent_hex            String?  @db.VarChar(10)
  badge_copy            String?  @db.VarChar(50)
  sort_order            Int      @default(0)
  is_active             Boolean  @default(true)
  created_at            DateTime @default(now()) @db.Timestamp(6)
}

model colive_property_content {
  id                    String           @id @db.VarChar(36)
  property_id           String           @db.VarChar(36)
  location_id           String           @db.VarChar(36)
  slug                  String           @unique @db.VarChar(100)
  headline              String?          @db.VarChar(200)
  subheadline           String?          @db.VarChar(300)
  description           String?
  microcopy             String?          @db.VarChar(300)
  hero_image_url        String?          @db.VarChar(500)
  secondary_image_url   String?          @db.VarChar(500)
  supporting_image_urls Json?            @default("[]")
  gallery_count         Int?
  primary_tag           String?          @db.VarChar(50)
  secondary_tag         String?          @db.VarChar(50)
  rating                Decimal?         @db.Decimal(2, 1)
  rating_label          String?          @db.VarChar(50)
  amenities             Json?            @default("[]")
  benefits              Json?            @default("[]")
  stories               Json?            @default("[]")
  checkout_notes        Json?            @default("[]")
  recommended_for       Json?            @default("[]")
  is_active             Boolean          @default(true)
  created_at            DateTime         @default(now()) @db.Timestamp(6)
  updated_at            DateTime         @default(now()) @db.Timestamp(6)
  properties            properties       @relation(fields: [property_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  colive_locations      colive_locations @relation(fields: [location_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([property_id], map: "idx_colive_content_property")
  @@index([location_id], map: "idx_colive_content_location")
}

model colive_room_options {
  id                   String                  @id @db.VarChar(36)
  property_id          String                  @db.VarChar(36)
  room_type_id         String                  @db.VarChar(36)
  slug                 String                  @db.VarChar(50)
  name                 String                  @db.VarChar(100)
  description          String?
  feature_points       Json?                   @default("[]")
  max_guests           Int?                    @default(1)
  recommended_for      Json?                   @default("[]")
  thumbnail_url        String?                 @db.VarChar(500)
  sort_order           Int                     @default(0)
  is_active            Boolean                 @default(true)
  created_at           DateTime                @default(now()) @db.Timestamp(6)
  properties           properties              @relation(fields: [property_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  room_types           room_types              @relation(fields: [room_type_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([property_id, slug])
  @@index([property_id, is_active], map: "idx_colive_rooms_property")
}

model colive_addons {
  id                   String     @id @db.VarChar(36)
  property_id          String     @db.VarChar(36)
  slug                 String     @db.VarChar(50)
  name                 String     @db.VarChar(100)
  description          String?
  pricing_model        String     @db.VarChar(20)
  unit_price           Decimal    @db.Decimal(10, 2)
  currency             String     @default("INR") @db.VarChar(5)
  max_quantity         Int?
  default_quantity     Int?       @default(0)
  category             String?    @db.VarChar(30)
  icon_hint            String?    @db.VarChar(50)
  is_available         Boolean    @default(true)
  availability_message String?    @db.VarChar(200)
  sort_order           Int        @default(0)
  is_active            Boolean    @default(true)
  created_at           DateTime   @default(now()) @db.Timestamp(6)
  properties           properties @relation(fields: [property_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([property_id, slug])
  @@index([property_id, is_active], map: "idx_colive_addons_property")
}

model colive_search_sessions {
  id              String   @id @db.VarChar(36)
  location_id     String?  @db.VarChar(36)
  location_slug   String?  @db.VarChar(50)
  move_in_date    String?  @db.VarChar(10)
  duration_months Int?
  stay_type       String?  @db.VarChar(20)
  guest_count     Int?
  plan_id         String?  @db.VarChar(36)
  currency        String?  @default("INR") @db.VarChar(5)
  result_count    Int?
  created_at      DateTime @default(now()) @db.Timestamp(6)

  @@index([location_slug, created_at], map: "idx_colive_search_location")
}

model colive_quotes {
  id                  String     @id @db.VarChar(36)
  property_id         String     @db.VarChar(36)
  guest_id            String?    @db.VarChar(36)
  room_option_id      String     @db.VarChar(36)
  move_in_date        DateTime   @db.Date
  duration_days       Int
  stay_type           String     @db.VarChar(20)
  room_line_total     Decimal    @db.Decimal(10, 2)
  addons_json         Json?      @default("[]")
  included_items_json Json?      @default("[]")
  room_subtotal       Decimal    @db.Decimal(10, 2)
  addon_subtotal      Decimal    @db.Decimal(10, 2)
  discount_total      Decimal    @default(0) @db.Decimal(10, 2)
  deposit_total       Decimal    @default(0) @db.Decimal(10, 2)
  tax_total           Decimal    @db.Decimal(10, 2)
  grand_total         Decimal    @db.Decimal(10, 2)
  monthly_savings     Decimal?   @db.Decimal(10, 2)
  total_savings       Decimal?   @db.Decimal(10, 2)
  pricing_notes_json  Json?      @default("[]")
  coupon_code         String?    @db.VarChar(30)
  currency            String     @default("INR") @db.VarChar(5)
  ezee_rate_per_night Decimal?   @db.Decimal(10, 2)
  expires_at          DateTime   @db.Timestamp(6)
